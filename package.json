{
  "name": "gestion-electrification-massive",
  "version": "0.1.0",
  "description": "Application bureau pour pilotage d'électrification de masse",
  "main": "electron/main.js",
  "scripts": {
    "start": "cd frontend && npm run dev",
    "electron:dev": "electron .",
    "build:electron": "vite build && electron-builder --win --x64",
    "package-win": "npm run build:electron",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/playwright/smoke.spec.js tests/playwright/rapports.spec.js",
    "test:unit": "vitest run tests/unit --reporter dot",
    "test": "npm run test:unit && npm run test:smoke",
    "lint": "echo \"Add eslint later\" && exit 0",
    "format": "echo \"Add prettier later\" && exit 0",
    "build:css": "tailwindcss -i src/styles.css -o src/output.css --watch",
    "build:css:prod": "tailwindcss -i src/styles.css -o src/output.css --minify",
    "dev": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:saas": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.13"
  },
  "build": {
    "appId": "com.proquelec.electrification",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    }
  },
  "dependencies": {
    "dompurify": "^3.3.1",
    "keytar": "^7.9.0"
  }
}
