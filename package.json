{
  "name": "gestion-electrification-massive",
  "version": "0.1.0",
  "description": "Application SaaS pour pilotage d'électrification de masse",
  "scripts": {
    "start": "cd frontend && npm run dev",
    "test:e2e": "npx playwright test -c frontend/playwright.config.ts",
    "test:e2e:headed": "npx playwright test -c frontend/playwright.config.ts --headed",
    "test:smoke": "playwright test tests/playwright/smoke.spec.js tests/playwright/rapports.spec.js",
    "test:unit": "cd frontend && npm run test:unit",
    "test": "npm run test:unit && npm run test:smoke",
    "lint": "echo \"Add eslint later\" && exit 0",
    "format": "echo \"Add prettier later\" && exit 0",
    "build:css": "tailwindcss -i src/styles.css -o src/output.css --watch",
    "build:css:prod": "tailwindcss -i src/styles.css -o src/output.css --minify",
    "dev": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev -- --host 0.0.0.0 --port 5173",
    "dev:saas": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "pmtiles:install": "cd backend\\pmtiles-server && npm install",
    "pmtiles:dev": "cd backend\\pmtiles-server && npm run dev",
    "pmtiles:start": "cd backend\\pmtiles-server && npm run start",
    "agent:deploy": "node scripts/local-deploy-agent.mjs",
    "smoke:internal-kobo": "node scripts/internal-kobo-smoke.mjs",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "mentor:audit": "node --experimental-strip-types ./scripts/mission_sage_auto_audit.ts",
    "prepare": "husky || exit 0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^3.4.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dompurify": "^3.4.1"
  }
}
