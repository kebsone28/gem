    "lint:report": "eslint src/ --ext .ts,.tsx --format stylish",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,js,json,md}'",
    "preview": "vite preview --host 0.0.0.0 --port $PORT",
    "dev:3000": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js --port 3000",
