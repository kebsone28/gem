{
  "customSyntax": "postcss-html",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "layer", "apply", "variants", "responsive", "screen"]
      }
    ],
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": ["--org-primary", "--preset-c"]
      }
    ]
  }
}