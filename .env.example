# ====== Port Mapping ======
# Docker Compose (docker-compose.yml)       Dev (local)
# ─────────────────────────────────────────────────────
# Nginx   → 8088  (GED_OS_HTTP_PORT)       Vite dev → 8889 → proxy → api
# API     → 5009  (GED_OS_API_PORT)         Backend  → 5005
# DB      → 5435  (GED_OS_DB_PORT)
# OSRM    → 5010  (GED_OS_OSRM_PORT)
# Vite proxy default target: 5009 (matches Docker)
# Override with VITE_API_PROXY_TARGET for custom setups

# ====== Database ======
DB_NAME=proquelec_saa
DB_USER=proquelec
# NEVER commit real passwords — use env vars or .env.local
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ====== API ======
NODE_ENV=development
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
PORT=5005

# ====== Docker GED OS ports ======
GED_OS_HTTP_PORT=8088
GED_OS_API_PORT=5009
GED_OS_DB_PORT=5435
GED_OS_OSRM_PORT=5010
GED_OS_MARTIN_PORT=3008
CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:5173,http://localhost:8889

# ====== Kobo (optional) ======
KOBO_API_URL=https://kc.kobotoolbox.org
KOBO_TOKEN=
