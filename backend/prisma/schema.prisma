generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  config          Json             @default("{}")
  createdAt       DateTime         @default(now())
  auditLogs       AuditLog[]
  grappes         Grappe[]
  missions        Mission[]
  performanceLogs PerformanceLog[]
  projects        Project[]
  teams           Team[]
  users           User[]
}

model User {
  id                 String           @id @default(uuid())
  organizationId     String
  email              String           @unique
  name               String?
  passwordHash       String
  roleLegacy         String           @default("user")
  roleId             String?
  lastLogin          DateTime?
  requires2FA        Boolean          @default(false)
  securityQuestion   String?
  securityAnswerHash String?
  recoveryCodeHash   String?
  active             Boolean          @default(true)
  permissions        Json?            @default("[]")
  notificationEmail  String?
  createdAt          DateTime         @default(now())
  auditLogs          AuditLog[]
  missions           Mission[]
  performanceLogs    PerformanceLog[]
  projectsUpdated    Project[]        @relation("UpdatedBy")
  syncLogs           SyncLog[]
  ledTeam            Team?            @relation("TeamLeader")
  organization       Organization     @relation(fields: [organizationId], references: [id])
  role               Role?            @relation(fields: [roleId], references: [id])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  status          String
  budget          Decimal
  duration        Int
  totalHouses     Int
  config          Json
  version         Int              @default(1)
  updatedAt       DateTime         @updatedAt
  updatedById     String?
  deletedAt       DateTime?
  missions        Mission[]
  performanceLogs PerformanceLog[]
  organization    Organization     @relation(fields: [organizationId], references: [id])
  updatedBy       User?            @relation("UpdatedBy", fields: [updatedById], references: [id])
  teams           Team[]
  zones           Zone[]
}

model Zone {
  id             String      @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  metadata       Json?       @default("{}")
  version        Int         @default(1)
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  households     Household[]
  teams          Team[]
  project        Project     @relation(fields: [projectId], references: [id])
}

model Household {
  id               String                   @id @default(uuid())
  zoneId           String?
  organizationId   String
  name             String?
  phone            String?
  region           String?
  departement      String?
  village          String?
  latitude         Float?
  longitude        Float?
  status           String
  location         Json
  location_gis     Unsupported("geometry")?
  owner            Json
  koboData         Json?                    @default("{}")
  koboSync         Json?                    @default("{}")
  koboSubmissionId BigInt?                  @unique
  numeroordre      String?
  constructionData Json?                    @default("{}")
  alerts           Json?                    @default("[]")
  source           String?
  version          Int                      @default(1)
  assignedTeams    String[]                 @default([])
  grappeId         String?
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  grappe           Grappe?                  @relation(fields: [grappeId], references: [id])
  zone             Zone?                    @relation(fields: [zoneId], references: [id])
  performanceLogs  PerformanceLog[]

  @@unique([numeroordre, organizationId])
  @@index([region])
  @@index([departement])
  @@index([village])
  @@index([assignedTeams])
  @@index([grappeId])
}

model Region {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  grappes   Grappe[]
  teams     Team[]
}

model Grappe {
  id             String       @id @default(uuid())
  name           String
  regionId       String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  region         Region       @relation(fields: [regionId], references: [id])
  households     Household[]
  teams          Team[]

  @@unique([name, regionId])
}

model Team {
  id              String           @id @default(uuid())
  name            String
  organizationId  String
  projectId       String
  parentTeamId    String?
  path            String?
  level           Int              @default(0)
  role            TeamRole         @default(INSTALLATION)
  tradeKey        String?
  capacity        Int?             @default(0)
  regionId        String?
  grappeId        String?
  zoneId          String?
  warehouseId     String?
  leaderId        String?          @unique
  status          String           @default("active")
  version         Int              @default(1)
  offlineId       String?          @unique
  syncStatus      SyncStatus       @default(SYNCED)
  updatedBy       String?
  legacyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  performanceLogs PerformanceLog[]
  grappe          Grappe?          @relation(fields: [grappeId], references: [id])
  leader          User?            @relation("TeamLeader", fields: [leaderId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])
  parent          Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  children        Team[]           @relation("TeamHierarchy")
  project         Project          @relation(fields: [projectId], references: [id])
  region          Region?          @relation(fields: [regionId], references: [id])
  zone            Zone?            @relation(fields: [zoneId], references: [id])

  @@index([organizationId])
  @@index([projectId, deletedAt])
  @@index([parentTeamId])
  @@index([regionId])
  @@index([path])
  @@index([role])
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String?
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime     @default(now())
  module         String?
  severity       String       @default("info")
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model PerformanceLog {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  teamId         String?
  userId         String?
  householdId    String?
  action         String
  oldStatus      String?
  newStatus      String?
  tradeKey       String?
  details        Json?
  timestamp      DateTime     @default(now())
  household      Household?   @relation(fields: [householdId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id])
  team           Team?        @relation(fields: [teamId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([projectId, timestamp])
  @@index([teamId, timestamp])
  @@index([userId, timestamp])
}

model Mission {
  id               String                   @id @default(uuid())
  organizationId   String
  projectId        String?
  orderNumber      String?                  @unique
  title            String?
  description      String?
  status           String                   @default("draft")
  startDate        DateTime?
  endDate          DateTime?
  budget           Decimal?
  createdBy        String?
  data             Json?                    @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  user             User?                    @relation(fields: [createdBy], references: [id])
  organization     Organization             @relation(fields: [organizationId], references: [id])
  project          Project?                 @relation(fields: [projectId], references: [id])
  approvalWorkflow MissionApprovalWorkflow?

  @@index([organizationId])
  @@index([projectId])
  @@index([orderNumber])
}

model MissionApprovalWorkflow {
  id                     String                @id @default(uuid())
  missionId              String                @unique
  overallStatus          String                @default("pending")
  currentStep            Int                   @default(1)
  orderNumber            String?
  orderNumberGeneratedAt DateTime?
  orderNumberGeneratedBy String?
  orderNumberOverridenAt DateTime?
  orderNumberOverridenBy String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  approvalSteps          MissionApprovalStep[]
  mission                Mission               @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([orderNumber])
}

model MissionApprovalStep {
  id         String                  @id @default(uuid())
  workflowId String
  role       String
  label      String?
  sequence   Int
  status     String                  @default("EN_ATTENTE")
  decidedBy  String?
  decidedAt  DateTime?
  comment    String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  workflow   MissionApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, role])
  @@index([workflowId])
  @@index([role])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum TeamRole {
  PREPARATION
  INSTALLATION
  SUPERVISION
  LOGISTICS
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
}
