generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  users     User[]
  projects  Project[]
  teams     Team[]
  createdAt DateTime  @default(now())
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  passwordHash   String
  role           String       @default("user")
  lastLogin      DateTime?
  projectsUpdated Project[]   @relation("UpdatedBy")
  syncLogs       SyncLog[]
  createdAt      DateTime     @default(now())
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  status         String
  budget         Decimal
  duration       Int
  totalHouses    Int
  config         Json
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  updatedById    String?
  updatedBy      User?        @relation("UpdatedBy", fields: [updatedById], references: [id])
  deletedAt      DateTime?
  zones          Zone[]
}

model Zone {
  id             String       @id @default(uuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  organizationId String
  name           String
  metadata       Json?        @default("{}")
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  households     Household[]
}

model Household {
  id             String       @id @default(uuid())
  zoneId         String
  zone           Zone         @relation(fields: [zoneId], references: [id])
  organizationId String
  status         String
  location       Json
  owner          Json
  koboData       Json?        @default("{}")
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model Team {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  type           String
  status         String
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
}
