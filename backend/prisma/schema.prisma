generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model Organization {
  id                         String                     @id @default(uuid())
  name                       String
  config                     Json                       @default("{}")
  createdAt                  DateTime                   @default(now())
  defaultProjectId           String?
  slug                       String?                    @unique
  auditLogs                  AuditLog[]
  automatedActions           AutomatedAction[]
  campaigns                  Campaign[]
  conflictLogs               ConflictLog[]
  dataCollectionSurveys      DataCollectionSurvey[]
  documents                  Document[]
  domainConfigs              DomainConfig[]
  eventLogs                  EventLog[]
  fields                     Field[]
  financialCharges           FinancialCharge[]
  formationModules           FormationModule[]
  formationPlannerStates     FormationPlannerState?
  formationPlanningHistories FormationPlanningHistory[]
  formationSessions          FormationSession[]
  grappes                    Grappe[]
  healthCenters              HealthCenter[]
  highVoltageNetworks        HighVoltageNetwork[]
  internalKoboSubmissions    InternalKoboSubmission[]
  koboFormMappings           KoboFormMapping[]
  livestocks                 Livestock[]
  missions                   Mission[]
  performanceLogs            PerformanceLog[]
  policies                   Policy[]
  projects                   Project[]
  shipments                  Shipment[]
  solarInstallations         SolarInstallation[]
  syncLogs                   SyncLog[]
  targetingCampaigns         TargetingCampaign[]
  teams                      Team[]
  users                      User[]
  warehouses                 Warehouse[]
  workflows                  Workflow[]
  mesRecords                 MESRecord[]
}

model User {
  id                       String                   @id @default(uuid())
  organizationId           String
  email                    String
  name                     String?
  passwordHash             String
  roleLegacy               String                   @default("user")
  roleId                   String?
  lastLogin                DateTime?
  requires2FA              Boolean                  @default(false)
  securityQuestion         String?
  securityAnswerHash       String?
  recoveryCodeHash         String?
  active                   Boolean                  @default(true)
  permissions              Json?                    @default("[]")
  notificationEmail        String?
  createdAt                DateTime                 @default(now())
  chatStatus               String                   @default("ONLINE")
  chatStatusText           String?
  actionApprovals          ActionApproval[]
  auditLogs                AuditLog[]
  validatedActions         AutomatedAction[]
  chatCreated              ChatConversation[]       @relation("ChatConversationCreator")
  chatMessages             ChatMessage[]            @relation("ChatMessageSender")
  chatParticipations       ChatParticipant[]
  chatBlocksIssued         ChatUserBlock[]          @relation("ChatBlockIssuer")
  chatBlocksReceived       ChatUserBlock[]          @relation("ChatBlockedUser")
  uploadedDocuments        Document[]               @relation("DocumentUploader")
  uploadedDocumentVersions DocumentVersion[]        @relation("DocumentVersionUploader")
  eventLogs                EventLog[]
  internalKoboSubmissions  InternalKoboSubmission[]
  missions                 Mission[]
  performanceLogs          PerformanceLog[]
  projectsUpdated          Project[]                @relation("UpdatedBy")
  syncLogs                 SyncLog[]
  ledTeam                  Team?                    @relation("TeamLeader")
  organization             Organization             @relation(fields: [organizationId], references: [id])
  role                     Role?                    @relation(fields: [roleId], references: [id])
  userMemory               UserMemory?
  mesRecordsControlled     MESRecord[]              @relation("MESController")
  mesRecordsValidated      MESRecord[]              @relation("MESValidator")
  mesControls              MESControl[]

  @@unique([email, organizationId])
}

model Project {
  id                    String                 @id @default(uuid())
  organizationId        String
  name                  String
  status                String
  budget                Decimal
  duration              Int
  totalHouses           Int
  config                Json
  version               Int                    @default(1)
  updatedAt             DateTime               @updatedAt
  updatedById           String?
  deletedAt             DateTime?
  templateKey           String?
  templateVersion       Int?
  automatedActions      AutomatedAction[]
  campaigns             Campaign[]
  dataCollectionSurveys DataCollectionSurvey[]
  documents             Document[]
  eventLogs             EventLog[]
  fields                Field[]
  financialCharges      FinancialCharge[]
  healthCenters         HealthCenter[]
  highVoltageNetworks   HighVoltageNetwork[]
  households            Household[]
  livestocks            Livestock[]
  missions              Mission[]
  performanceLogs       PerformanceLog[]
  policies              Policy[]
  organization          Organization           @relation(fields: [organizationId], references: [id])
  updatedBy             User?                  @relation("UpdatedBy", fields: [updatedById], references: [id])
  projectModules        ProjectModule[]
  projectPages          ProjectPage[]
  shipments             Shipment[]
  solarInstallations    SolarInstallation[]
  targetingCampaigns    TargetingCampaign[]
  teams                 Team[]
  warehouses            Warehouse[]
  workflows             Workflow[]
  zones                 Zone[]
  mesRecords            MESRecord[]
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  config      Json     @default("{}")
  modules     Json?    @default("[]")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectPage {
  id        String  @id @default(uuid())
  projectId String
  key       String
  name      String
  icon      String?
  route     String?
  enabled   Boolean @default(true)
  order     Int     @default(0)
  config    Json?   @default("{}")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
}

model ProjectModule {
  id        String     @id @default(uuid())
  projectId String
  key       String
  name      String
  enabled   Boolean    @default(true)
  config    Json?      @default("{}")
  fields    Json?      @default("[]")
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflows Workflow[]

  @@unique([projectId, key])
  @@index([projectId])
}

model Zone {
  id             String      @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  metadata       Json?       @default("{}")
  version        Int         @default(1)
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  households     Household[]
  teams          Team[]
  project        Project     @relation(fields: [projectId], references: [id])
}

model Household {
  id                      String                   @id @default(uuid())
  zoneId                  String?
  organizationId          String
  name                    String?
  phone                   String?
  region                  String?
  departement             String?
  village                 String?
  latitude                Float?
  longitude               Float?
  status                  String
  location                Json
  location_gis            Unsupported("geometry")?
  owner                   Json
  koboData                Json?                    @default("{}")
  koboSync                Json?                    @default("{}")
  koboSubmissionId        BigInt?                  @unique
  numeroordre             String?
  constructionData        Json?                    @default("{}")
  alerts                  Json?                    @default("[]")
  source                  String?
  version                 Int                      @default(1)
  manualOverrides         String[]                 @default([])
  assignedTeams           String[]                 @default([])
  grappeId                String?
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  projectId               String?
  grappe                  Grappe?                  @relation(fields: [grappeId], references: [id])
  project                 Project?                 @relation(fields: [projectId], references: [id])
  zone                    Zone?                    @relation(fields: [zoneId], references: [id])
  internalKoboSubmissions InternalKoboSubmission[]
  performanceLogs         PerformanceLog[]

  @@unique([numeroordre, organizationId])
  @@index([region])
  @@index([departement])
  @@index([village])
  @@index([assignedTeams])
  @@index([grappeId])
  @@index([zoneId, organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@index([projectId])
}

model Region {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  grappes   Grappe[]
  teams     Team[]
}

model Grappe {
  id             String       @id @default(uuid())
  name           String
  regionId       String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  region         Region       @relation(fields: [regionId], references: [id])
  households     Household[]
  teams          Team[]

  @@unique([name, regionId])
}

model Team {
  id              String           @id @default(uuid())
  name            String
  organizationId  String
  projectId       String
  parentTeamId    String?
  path            String?
  level           Int              @default(0)
  role            TeamRole         @default(INSTALLATION)
  tradeKey        String?
  capacity        Int?             @default(0)
  regionId        String?
  grappeId        String?
  zoneId          String?
  warehouseId     String?
  leaderId        String?          @unique
  status          String           @default("active")
  version         Int              @default(1)
  offlineId       String?          @unique
  syncStatus      SyncStatus       @default(SYNCED)
  updatedBy       String?
  legacyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  performanceLogs PerformanceLog[]
  grappe          Grappe?          @relation(fields: [grappeId], references: [id])
  leader          User?            @relation("TeamLeader", fields: [leaderId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])
  parent          Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  children        Team[]           @relation("TeamHierarchy")
  project         Project          @relation(fields: [projectId], references: [id])
  region          Region?          @relation(fields: [regionId], references: [id])
  zone            Zone?            @relation(fields: [zoneId], references: [id])

  @@index([organizationId])
  @@index([projectId, deletedAt])
  @@index([parentTeamId])
  @@index([regionId])
  @@index([path])
  @@index([role])
}

model SyncLog {
  id             String       @id @default(uuid())
  userId         String
  deviceId       String
  timestamp      DateTime     @default(now())
  action         String
  details        Json
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model ConflictLog {
  id             String       @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  clientVersion  Int?
  serverVersion  Int?
  localData      Json?
  serverData     Json?
  resolvedData   Json?
  strategy       String       @default("last-write-wins")
  timestamp      DateTime     @default(now())
  resolved       Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

model KoboFormMapping {
  id             String       @id @default(uuid())
  organizationId String
  koboAssetId    String
  mapping        Json
  version        String
  lastValidated  DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, koboAssetId])
  @@index([organizationId])
  @@index([koboAssetId])
}

model InternalKoboSubmission {
  id                 String       @id @default(uuid())
  organizationId     String
  householdId        String?
  numeroOrdre        String?
  formKey            String       @default("terrain_internal")
  formVersion        String
  clientSubmissionId String
  role               String?
  status             String       @default("draft")
  syncStatus         String       @default("synced")
  values             Json
  metadata           Json?        @default("{}")
  requiredMissing    String[]     @default([])
  submittedById      String?
  submittedAt        DateTime?
  savedAt            DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  household          Household?   @relation(fields: [householdId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id])
  submittedBy        User?        @relation(fields: [submittedById], references: [id])

  @@unique([organizationId, clientSubmissionId])
  @@index([organizationId, householdId])
  @@index([organizationId, numeroOrdre])
  @@index([organizationId, formKey, formVersion])
  @@index([organizationId, status, syncStatus])
  @@index([savedAt])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String?
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime     @default(now())
  module         String?
  severity       String       @default("info")
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model PerformanceLog {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  teamId         String?
  userId         String?
  householdId    String?
  action         String
  oldStatus      String?
  newStatus      String?
  tradeKey       String?
  details        Json?
  timestamp      DateTime     @default(now())
  household      Household?   @relation(fields: [householdId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id])
  team           Team?        @relation(fields: [teamId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([projectId, timestamp])
  @@index([teamId, timestamp])
  @@index([userId, timestamp])
}

model Mission {
  id                 String                   @id @default(uuid())
  organizationId     String
  projectId          String?
  orderNumber        String?                  @unique
  title              String?
  description        String?
  status             String                   @default("draft")
  startDate          DateTime?
  endDate            DateTime?
  budget             Decimal?
  createdBy          String?
  data               Json?                    @default("{}")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?
  excludeFromFinance Boolean                  @default(false)
  user               User?                    @relation(fields: [createdBy], references: [id])
  organization       Organization             @relation(fields: [organizationId], references: [id])
  project            Project?                 @relation(fields: [projectId], references: [id])
  approvalWorkflow   MissionApprovalWorkflow?

  @@index([organizationId])
  @@index([projectId])
  @@index([orderNumber])
  @@index([createdBy])
  @@index([status, deletedAt])
  @@index([organizationId, createdBy])
  @@index([organizationId, status, createdAt])
  @@index([projectId, createdBy])
}

model MissionApprovalWorkflow {
  id                     String                @id @default(uuid())
  missionId              String                @unique
  overallStatus          String                @default("pending")
  currentStep            Int                   @default(1)
  orderNumber            String?
  orderNumberGeneratedAt DateTime?
  orderNumberGeneratedBy String?
  orderNumberOverridenAt DateTime?
  orderNumberOverridenBy String?
  integrityHash          String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  approvalSteps          MissionApprovalStep[]
  mission                Mission               @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([orderNumber])
}

model MissionApprovalStep {
  id         String                  @id @default(uuid())
  workflowId String
  role       String
  label      String?
  sequence   Int
  status     String                  @default("EN_ATTENTE")
  decidedBy  String?
  decidedAt  DateTime?
  comment    String?
  signature  String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  workflow   MissionApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, role])
  @@index([workflowId])
  @@index([role])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserMemory {
  id             String         @id @default(cuid())
  userId         String         @unique
  lastMessage    String?
  lastIntent     String?
  preferences    Json?
  history        Json?
  emotions       Json?
  context        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  vectorMemories VectorMemory[]

  @@index([userId])
}

model VectorMemory {
  id             String     @id @default(cuid())
  userId         String
  userMemoryId   String
  organizationId String?
  content        String
  embedding      Json?
  metadata       Json?
  intent         String?
  emotion        String?
  source         String     @default("conversation")
  importance     Float      @default(0.5)
  createdAt      DateTime   @default(now())
  expiresAt      DateTime?
  lastAccessed   DateTime   @default(now())
  accessCount    Int        @default(0)
  userMemory     UserMemory @relation(fields: [userMemoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userMemoryId])
  @@index([createdAt])
  @@index([expiresAt])
}

model AIMetrics {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String?
  requestType     String
  routeSelected   String
  inputTokens     Int?
  outputTokens    Int?
  costUSD         Decimal?
  latencyMs       Int?
  success         Boolean  @default(true)
  errorMessage    String?
  intentDetected  String?
  emotionDetected String?
  cacheHitRate    Float?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([routeSelected])
}

model PromptVersion {
  id             String    @id @default(cuid())
  organizationId String?
  name           String
  version        Int
  prompt         String
  model          String?
  description    String?
  isActive       Boolean   @default(false)
  testResults    Json?
  metrics        Json?
  createdAt      DateTime  @default(now())
  activatedAt    DateTime?
  deactivatedAt  DateTime?

  @@unique([name, version])
  @@index([organizationId])
  @@index([isActive])
  @@index([createdAt])
}

model ActionApproval {
  id               String    @id @default(cuid())
  organizationId   String
  userId           String?
  agentName        String
  actionType       String
  riskLevel        String
  confidence       Float
  status           String    @default("AUTO_EXECUTED")
  payload          Json
  result           Json?
  error            String?
  requestedBy      String?
  approvedBy       String?
  rejectedBy       String?
  rejectionComment String?
  requestedAt      DateTime  @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  executedAt       DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User?     @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([userId])
  @@index([agentName])
  @@index([requestedAt])
  @@index([riskLevel])
}

model Alert {
  id                         String    @id @default(cuid())
  organizationId             String
  projectId                  String
  householdId                String?
  pvId                       String?
  type                       String
  severity                   String
  status                     String    @default("OPEN")
  title                      String
  description                String?
  recommendedAction          String?
  createdAt                  DateTime  @default(now())
  acknowledgedAt             DateTime?
  acknowledgedBy             String?
  resolvedAt                 DateTime?
  resolvedBy                 String?
  escalatedAt                DateTime?
  escalationLevel            Int       @default(0)
  escalationNotificationSent Boolean   @default(false)
  notified                   Boolean   @default(false)
  smsNotified                Boolean   @default(false)
  emailNotified              Boolean   @default(false)
  metadata                   Json?

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([householdId])
}

model PVRecord {
  id             String    @id
  organizationId String
  projectId      String?
  householdId    String
  type           String
  content        String?
  createdBy      String?
  metadata       Json?     @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@index([projectId])
  @@index([householdId])
  @@index([type])
  @@index([createdAt])
}

model AlertConfiguration {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  stockCritical   Int      @default(5)
  budgetThreshold Float    @default(90)
  teamCapacity    Float    @default(85)
  electricityMin  Float    @default(50)
  delayThreshold  Int      @default(5)
  escalationDelay Int      @default(3600)
  escalationLoop  Boolean  @default(true)
  enableSMS       Boolean  @default(true)
  enableEmail     Boolean  @default(true)
  enablePush      Boolean  @default(false)
  enableWhatsApp  Boolean  @default(false)
  quietHourStart  Int?
  quietHourEnd    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

model FormationModule {
  id             String                   @id @default(uuid())
  name           String
  description    String?
  duration       Int
  order          Int                      @default(0)
  isActive       Boolean                  @default(true)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id])
  sessionModules FormationSessionModule[]

  @@index([organizationId])
}

model FormationSession {
  id              String                     @id @default(uuid())
  region          String
  salle           String
  maxParticipants Int
  startDate       DateTime
  endDate         DateTime?
  workSaturday    Boolean                    @default(false)
  workSunday      Boolean                    @default(false)
  status          String                     @default("PLANIFIEE")
  notes           String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  organizationId  String
  participants    FormationParticipant[]
  historyEntries  FormationPlanningHistory[]
  organization    Organization               @relation(fields: [organizationId], references: [id])
  sessionModules  FormationSessionModule[]

  @@index([organizationId])
  @@index([region])
  @@index([startDate])
  @@index([status])
}

model FormationSessionModule {
  id         String           @id @default(uuid())
  sessionId  String
  moduleId   String
  duration   Int
  orderIndex Int              @default(0)
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  module     FormationModule  @relation(fields: [moduleId], references: [id])
  session    FormationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, moduleId])
  @@index([sessionId])
  @@index([moduleId])
}

model FormationParticipant {
  id         String           @id @default(uuid())
  sessionId  String
  name       String
  email      String?
  phone      String?
  role       String?
  attendance Boolean          @default(false)
  createdAt  DateTime         @default(now())
  session    FormationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model FormationPlanningHistory {
  id             String            @id @default(uuid())
  sessionId      String?
  action         String
  title          String
  details        String?
  metadata       Json?
  createdAt      DateTime          @default(now())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  session        FormationSession? @relation(fields: [sessionId], references: [id])

  @@index([organizationId])
  @@index([sessionId])
  @@index([action])
  @@index([createdAt])
}

model FormationPlannerState {
  id             String       @id @default(uuid())
  payload        Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([updatedAt])
}

model ChatConversation {
  id             String            @id @default(uuid())
  organizationId String
  type           String
  name           String?
  scopeKey       String?
  createdById    String?
  archivedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  retentionDays  Int               @default(0)
  createdBy      User?             @relation("ChatConversationCreator", fields: [createdById], references: [id])
  messages       ChatMessage[]
  participants   ChatParticipant[]

  @@unique([organizationId, scopeKey])
  @@index([organizationId])
  @@index([type])
  @@index([updatedAt])
}

model ChatParticipant {
