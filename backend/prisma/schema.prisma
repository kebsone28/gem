generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  users     User[]
  projects  Project[]
  teams     Team[]
  createdAt DateTime  @default(now())
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String       @unique
  name           String?
  passwordHash   String
  role           String       @default("user")
  lastLogin      DateTime?
  requires2FA       Boolean      @default(false)
  securityQuestion  String?
  securityAnswerHash String?
  recoveryCodeHash  String?
  projectsUpdated Project[]   @relation("UpdatedBy")
  syncLogs       SyncLog[]
  auditLogs      AuditLog[]
  ledTeam        Team?        @relation("TeamLeader")
  createdAt      DateTime     @default(now())
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  status         String
  budget         Decimal
  duration       Int
  totalHouses    Int
  config         Json
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  updatedById    String?
  updatedBy      User?        @relation("UpdatedBy", fields: [updatedById], references: [id])
  deletedAt      DateTime?
  zones          Zone[]
  teams          Team[]
}

model Zone {
  id             String       @id @default(uuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  organizationId String
  name           String
  metadata       Json?        @default("{}")
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  households     Household[]
}

model Household {
  id             String       @id @default(uuid())
  zoneId         String
  zone           Zone         @relation(fields: [zoneId], references: [id])
  organizationId String
  status         String
  location       Json
  // location_gis   Unsupported("geometry(Point, 4326)")?
  owner          Json
  koboData       Json?        @default("{}")
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model Team {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  leaderId       String?      @unique
  leader         User?        @relation("TeamLeader", fields: [leaderId], references: [id])
  name           String
  type           String
  status         String
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  action         String
  resource       String
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
}
