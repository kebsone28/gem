generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  config          Json             @default("{}")
  createdAt       DateTime         @default(now())
  auditLogs       AuditLog[]
  grappes         Grappe[]
  missions        Mission[]
  performanceLogs PerformanceLog[]
  projects        Project[]
  teams           Team[]
  users           User[]
}

model User {
  id                 String           @id @default(uuid())
  organizationId     String
  email              String           @unique
  name               String?
  passwordHash       String
  roleLegacy         String           @default("user")
  roleId             String?
  lastLogin          DateTime?
  requires2FA        Boolean          @default(false)
  securityQuestion   String?
  securityAnswerHash String?
  recoveryCodeHash   String?
  active             Boolean          @default(true)
  permissions        Json?            @default("[]")
  notificationEmail  String?
  createdAt          DateTime         @default(now())
  actionApprovals    ActionApproval[]
  auditLogs          AuditLog[]
  missions           Mission[]
  performanceLogs    PerformanceLog[]
  projectsUpdated    Project[]        @relation("UpdatedBy")
  syncLogs           SyncLog[]
  ledTeam            Team?            @relation("TeamLeader")
  userMemory        UserMemory?
  organization       Organization     @relation(fields: [organizationId], references: [id])
  role               Role?            @relation(fields: [roleId], references: [id])
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  status          String
  budget          Decimal
  duration        Int
  totalHouses     Int
  config          Json
  version         Int              @default(1)
  updatedAt       DateTime         @updatedAt
  updatedById     String?
  deletedAt       DateTime?
  missions        Mission[]
  performanceLogs PerformanceLog[]
  organization    Organization     @relation(fields: [organizationId], references: [id])
  updatedBy       User?            @relation("UpdatedBy", fields: [updatedById], references: [id])
  teams           Team[]
  zones           Zone[]
}

model Zone {
  id             String      @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  metadata       Json?       @default("{}")
  version        Int         @default(1)
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  households     Household[]
  teams          Team[]
  project        Project     @relation(fields: [projectId], references: [id])
}

model Household {
  id               String                   @id @default(uuid())
  zoneId           String?
  organizationId   String
  name             String?
  phone            String?
  region           String?
  departement      String?
  village          String?
  latitude         Float?
  longitude        Float?
  status           String
  location         Json
  location_gis     Unsupported("geometry")?
  owner            Json
  koboData         Json?                    @default("{}")
  koboSync         Json?                    @default("{}")
  koboSubmissionId BigInt?                  @unique
  numeroordre      String?
  constructionData Json?                    @default("{}")
  alerts           Json?                    @default("[]")
  source           String?
  version          Int                      @default(1)
  assignedTeams    String[]                 @default([])
  grappeId         String?
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  grappe           Grappe?                  @relation(fields: [grappeId], references: [id])
  zone             Zone?                    @relation(fields: [zoneId], references: [id])
  performanceLogs  PerformanceLog[]

  @@unique([numeroordre, organizationId])
  @@index([region])
  @@index([departement])
  @@index([village])
  @@index([assignedTeams])
  @@index([grappeId])
}

model Region {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  grappes   Grappe[]
  teams     Team[]
}

model Grappe {
  id             String       @id @default(uuid())
  name           String
  regionId       String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  region         Region       @relation(fields: [regionId], references: [id])
  households     Household[]
  teams          Team[]

  @@unique([name, regionId])
}

model Team {
  id              String           @id @default(uuid())
  name            String
  organizationId  String
  projectId       String
  parentTeamId    String?
  path            String?
  level           Int              @default(0)
  role            TeamRole         @default(INSTALLATION)
  tradeKey        String?
  capacity        Int?             @default(0)
  regionId        String?
  grappeId        String?
  zoneId          String?
  warehouseId     String?
  leaderId        String?          @unique
  status          String           @default("active")
  version         Int              @default(1)
  offlineId       String?          @unique
  syncStatus      SyncStatus       @default(SYNCED)
  updatedBy       String?
  legacyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  performanceLogs PerformanceLog[]
  grappe          Grappe?          @relation(fields: [grappeId], references: [id])
  leader          User?            @relation("TeamLeader", fields: [leaderId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])
  parent          Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  children        Team[]           @relation("TeamHierarchy")
  project         Project          @relation(fields: [projectId], references: [id])
  region          Region?          @relation(fields: [regionId], references: [id])
  zone            Zone?            @relation(fields: [zoneId], references: [id])

  @@index([organizationId])
  @@index([projectId, deletedAt])
  @@index([parentTeamId])
  @@index([regionId])
  @@index([path])
  @@index([role])
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String?
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime     @default(now())
  module         String?
  severity       String       @default("info")
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model PerformanceLog {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  teamId         String?
  userId         String?
  householdId    String?
  action         String
  oldStatus      String?
  newStatus      String?
  tradeKey       String?
  details        Json?
  timestamp      DateTime     @default(now())
  household      Household?   @relation(fields: [householdId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id])
  team           Team?        @relation(fields: [teamId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([projectId, timestamp])
  @@index([teamId, timestamp])
  @@index([userId, timestamp])
}

model Mission {
  id               String                   @id @default(uuid())
  organizationId   String
  projectId        String?
  orderNumber      String?                  @unique
  title            String?
  description      String?
  status           String                   @default("draft")
  startDate        DateTime?
  endDate          DateTime?
  budget           Decimal?
  createdBy        String?
  data             Json?                    @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  user             User?                    @relation(fields: [createdBy], references: [id])
  organization     Organization             @relation(fields: [organizationId], references: [id])
  project          Project?                 @relation(fields: [projectId], references: [id])
  approvalWorkflow MissionApprovalWorkflow?

  @@index([organizationId])
  @@index([projectId])
  @@index([orderNumber])
}

model MissionApprovalWorkflow {
  id                     String                @id @default(uuid())
  missionId              String                @unique
  overallStatus          String                @default("pending")
  currentStep            Int                   @default(1)
  orderNumber            String?
  orderNumberGeneratedAt DateTime?
  orderNumberGeneratedBy String?
  orderNumberOverridenAt DateTime?
  orderNumberOverridenBy String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  approvalSteps          MissionApprovalStep[]
  mission                Mission               @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([orderNumber])
}

model MissionApprovalStep {
  id         String                  @id @default(uuid())
  workflowId String
  role       String
  label      String?
  sequence   Int
  status     String                  @default("EN_ATTENTE")
  decidedBy  String?
  decidedAt  DateTime?
  comment    String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  workflow   MissionApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, role])
  @@index([workflowId])
  @@index([role])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserMemory {
  id            String   @id @default(cuid())
  userId        String   @unique

  lastMessage   String?
  lastIntent    String?

  preferences   Json?
  history       Json?
  emotions      Json?
  context       Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  vectorMemories VectorMemory[]

  @@index([userId])
}

model VectorMemory {
  id            String     @id @default(cuid())
  userId        String
  userMemoryId  String
  organizationId String?
  
  content       String     // Original text content
  embedding     Json?      // OpenAI embedding stored as JSON array
  metadata      Json?      // Additional metadata for semantic search and recall
  
  intent        String?    // e.g., "technical_issue", "greeting"
  emotion       String?    // e.g., "stressed", "neutral"
  source        String     @default("conversation") // "conversation", "document", "feedback"
  importance    Float      @default(0.5) // 0.0-1.0 relevance score
  
  createdAt     DateTime   @default(now())
  expiresAt     DateTime?  // For auto-cleanup of old memories
  lastAccessed  DateTime   @default(now())
  accessCount   Int        @default(0)
  
  userMemory    UserMemory @relation(fields: [userMemoryId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userMemoryId])
  @@index([createdAt])
  @@index([expiresAt])
}

model AIMetrics {
  id               String   @id @default(cuid())
  userId           String
  organizationId   String?
  
  requestType      String   // "query", "memory_store", "memory_search"
  routeSelected    String   // "local", "ai", "hybrid", "cache"
  
  inputTokens      Int?     // For LLM calls
  outputTokens     Int?     // For LLM calls
  costUSD          Decimal? // Calculated cost
  latencyMs        Int?     // Response time
  
  success          Boolean  @default(true)
  errorMessage     String?
  
  intentDetected   String?
  emotionDetected  String?
  cacheHitRate     Float?   // % of queries served from cache
  
  createdAt        DateTime @default(now())
  
  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([routeSelected])
}

model PromptVersion {
  id               String   @id @default(cuid())
  organizationId   String?
  
  name             String   // e.g., "system_prompt_v1", "mission_routing_v2"
  version          Int      // Sequential version number
  prompt           String   // Full prompt text
  model            String?  // GPT model it was designed for
  description      String?
  
  isActive         Boolean  @default(false)
  testResults      Json?    // {success_rate: 0.95, avg_latency_ms: 250}
  metrics          Json?    // {cost_optimization: 0.7, quality_score: 0.92}
  
  createdAt        DateTime @default(now())
  activatedAt      DateTime?
  deactivatedAt    DateTime?
  
  @@unique([name, version])
  @@index([organizationId])
  @@index([isActive])
  @@index([createdAt])
}

model ActionApproval {
  id                String    @id @default(cuid())
  organizationId    String
  userId            String?
  agentName         String    // TechAgent, DataAgent, SupportAgent, MissionSage
  actionType        String    // createMission, assignTechnician, modifyData, etc.
  riskLevel         String    // LOW, MEDIUM, HIGH
  confidence        Float     // 0.0 - 1.0 (AI confidence score)
  
  status            String    @default("AUTO_EXECUTED") // AUTO_EXECUTED, PENDING, APPROVED, REJECTED, EXECUTED, FAILED
  
  payload           Json      // Full action payload
  result            Json?     // Execution result
  error             String?   // Error message if failed
  
  requestedBy       String?   // User or system that requested
  approvedBy        String?   // User who approved
  rejectedBy        String?   // User who rejected
  rejectionComment  String?   // Why it was rejected
  
  requestedAt       DateTime  @default(now())
  approvedAt        DateTime?
  rejectedAt        DateTime?
  executedAt        DateTime?
  
  metadata          Json?     // Additional context: intent, emotion, model_used, latency_ms, etc.
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  user              User?     @relation(fields: [userId], references: [id])
  
  @@index([organizationId])
  @@index([status])
  @@index([userId])
  @@index([agentName])
  @@index([requestedAt])
  @@index([riskLevel])
}

model Alert {
  id              String    @id @default(cuid())
  organizationId  String
  projectId       String
  householdId     String?   // Alerte liée à un ménage (PVNC, PVHSE, etc.)
  pvId            String?   // Alerte liée à un PV généré
  
  type            String    // PVNC, PVHSE, PVRET, PVRD, PVRES, IGPP_STOCK, IGPP_BUDGET, HSE_INCIDENT, etc.
  severity        String    // CRITICAL, HIGH, MEDIUM, LOW
  status          String    @default("OPEN")  // OPEN, ACKNOWLEDGED, RESOLVED, ESCALATED
  
  title           String
  description     String?
  recommendedAction String?
  
  // Traçabilité de l'alerte
  createdAt       DateTime  @default(now())
  acknowledgedAt  DateTime?
  acknowledgedBy  String?   // ID utilisateur qui a reconnu l'alerte
  resolvedAt      DateTime?
  resolvedBy      String?   // ID utilisateur qui a résolu
  
  // Escalade automatique
  escalatedAt     DateTime?
  escalationLevel Int       @default(0) // 0 = initial, 1 = escalade 1, etc.
  escalationNotificationSent Boolean @default(false)
  
  // Notifications
  notified        Boolean   @default(false)
  smsNotified     Boolean   @default(false)
  emailNotified   Boolean   @default(false)
  
  // Métadonnées
  metadata        Json?     // Données supplémentaires: seuils, valeurs actuelles, etc.
  
  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([householdId])
}

model AlertConfiguration {
  id              String    @id @default(cuid())
  organizationId  String    @unique
  
  // Seuils IGPP
  stockCritical   Int       @default(5)       // Nombre d'alertes avant critique
  budgetThreshold Float     @default(90)      // Pourcentage d'utilisation
  teamCapacity    Float     @default(85)      // Pourcentage de capacité
  electricityMin  Float     @default(50)      // Pourcentage minimum
  delayThreshold  Int       @default(5)       // Jours avant retard
  
  // Escalade
  escalationDelay Int       @default(3600)    // Secondes avant escalade (1h)
  escalationLoop  Boolean   @default(true)    // Ré-notifier après escalade?
  
  // Canaux
  enableSMS       Boolean   @default(true)
  enableEmail     Boolean   @default(true)
  enablePush      Boolean   @default(false)
  enableWhatsApp  Boolean   @default(false)
  
  // Horaires
  quietHourStart  Int?      // 0-23 (optionnel)
  quietHourEnd    Int?      // 0-23 (optionnel)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([organizationId])
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum TeamRole {
  PREPARATION
  INSTALLATION
  SUPERVISION
  LOGISTICS
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
}
