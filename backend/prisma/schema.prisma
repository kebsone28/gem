generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

model Organization {
  id              String           @id @default(uuid())
  name            String
  config          Json             @default("{}")
  createdAt       DateTime         @default(now())
  auditLogs       AuditLog[]
  grappes         Grappe[]
  missions        Mission[]
  performanceLogs PerformanceLog[]
  projects        Project[]
  teams           Team[]
  users           User[]
  conflictLogs    ConflictLog[]
  syncLogs        SyncLog[]
  koboFormMappings KoboFormMapping[]
}

model User {
  id                 String           @id @default(uuid())
  organizationId     String
  email              String           @unique
  name               String?
  passwordHash       String
  roleLegacy         String           @default("user")
  roleId             String?
  lastLogin          DateTime?
  requires2FA        Boolean          @default(false)
  securityQuestion   String?
  securityAnswerHash String?
  recoveryCodeHash   String?
  active             Boolean          @default(true)
  permissions        Json?            @default("[]")
  notificationEmail  String?
  createdAt          DateTime         @default(now())
  actionApprovals    ActionApproval[]
  auditLogs          AuditLog[]
  missions           Mission[]
  performanceLogs    PerformanceLog[]
  projectsUpdated    Project[]        @relation("UpdatedBy")
  syncLogs           SyncLog[]
  ledTeam            Team?            @relation("TeamLeader")
  organization       Organization     @relation(fields: [organizationId], references: [id])
  role               Role?            @relation(fields: [roleId], references: [id])
  userMemory         UserMemory?
}

model Project {
  id              String           @id @default(uuid())
  organizationId  String
  name            String
  status          String
  budget          Decimal
  duration        Int
  totalHouses     Int
  config          Json
  version         Int              @default(1)
  updatedAt       DateTime         @updatedAt
  updatedById     String?
  deletedAt       DateTime?
  missions        Mission[]
  performanceLogs PerformanceLog[]
  organization    Organization     @relation(fields: [organizationId], references: [id])
  updatedBy       User?            @relation("UpdatedBy", fields: [updatedById], references: [id])
  teams           Team[]
  zones           Zone[]
}

model Zone {
  id             String      @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  metadata       Json?       @default("{}")
  version        Int         @default(1)
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  households     Household[]
  teams          Team[]
  project        Project     @relation(fields: [projectId], references: [id])
}

model Household {
  id               String                   @id @default(uuid())
  zoneId           String?
  organizationId   String
  name             String?
  phone            String?
  region           String?
  departement      String?
  village          String?
  latitude         Float?
  longitude        Float?
  status           String
  location         Json
  location_gis     Unsupported("geometry")?
  owner            Json
  koboData         Json?                    @default("{}")
  koboSync         Json?                    @default("{}")
  koboSubmissionId BigInt?                  @unique
  numeroordre      String?
  constructionData Json?                    @default("{}")
  alerts           Json?                    @default("[]")
  source           String?
  version          Int                      @default(1)
  manualOverrides  String[]                 @default([])
  assignedTeams    String[]                 @default([])
  grappeId         String?
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  grappe           Grappe?                  @relation(fields: [grappeId], references: [id])
  zone             Zone?                    @relation(fields: [zoneId], references: [id])
  performanceLogs  PerformanceLog[]

  @@unique([numeroordre, organizationId])
  @@index([region])
  @@index([departement])
  @@index([village])
  @@index([assignedTeams])
  @@index([grappeId])
  @@index([zoneId, organizationId])
  @@index([status])
  @@index([organizationId, status])
}

model Region {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  grappes   Grappe[]
  teams     Team[]
}

model Grappe {
  id             String       @id @default(uuid())
  name           String
  regionId       String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  region         Region       @relation(fields: [regionId], references: [id])
  households     Household[]
  teams          Team[]

  @@unique([name, regionId])
}

model Team {
  id              String           @id @default(uuid())
  name            String
  organizationId  String
  projectId       String
  parentTeamId    String?
  path            String?
  level           Int              @default(0)
  role            TeamRole         @default(INSTALLATION)
  tradeKey        String?
  capacity        Int?             @default(0)
  regionId        String?
  grappeId        String?
  zoneId          String?
  warehouseId     String?
  leaderId        String?          @unique
  status          String           @default("active")
  version         Int              @default(1)
  offlineId       String?          @unique
  syncStatus      SyncStatus       @default(SYNCED)
  updatedBy       String?
  legacyId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  performanceLogs PerformanceLog[]
  grappe          Grappe?          @relation(fields: [grappeId], references: [id])
  leader          User?            @relation("TeamLeader", fields: [leaderId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])
  parent          Team?            @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  children        Team[]           @relation("TeamHierarchy")
  project         Project          @relation(fields: [projectId], references: [id])
  region          Region?          @relation(fields: [regionId], references: [id])
  zone            Zone?            @relation(fields: [zoneId], references: [id])

  @@index([organizationId])
  @@index([projectId, deletedAt])
  @@index([parentTeamId])
  @@index([regionId])
  @@index([path])
  @@index([role])
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
  user      User     @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model ConflictLog {
  id             String       @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  clientVersion  Int?
  serverVersion  Int?
  localData      Json?
  serverData     Json?
  resolvedData   Json?
  strategy       String       @default("last-write-wins")
  timestamp      DateTime     @default(now())
  resolved       Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

// Mapping dynamique des champs Kobo vers GEM
model KoboFormMapping {
  id             String   @id @default(uuid())
  organizationId String
  koboAssetId    String   // ID du formulaire Kobo (asset uid)
  mapping        Json     // Mapping dynamique des champs
  version        String   // Version du formulaire Kobo
  lastValidated  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, koboAssetId])
  @@index([organizationId])
  @@index([koboAssetId])
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String?
  resourceId     String?
  details        Json?
  ipAddress      String?
  userAgent      String?
  timestamp      DateTime     @default(now())
  module         String?
  severity       String       @default("info")
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([timestamp])
  @@index([action])
}

model PerformanceLog {
  id             String       @id @default(uuid())
  organizationId String
  projectId      String
  teamId         String?
  userId         String?
  householdId    String?
  action         String
  oldStatus      String?
  newStatus      String?
  tradeKey       String?
  details        Json?
  timestamp      DateTime     @default(now())
  household      Household?   @relation(fields: [householdId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id])
  team           Team?        @relation(fields: [teamId], references: [id])
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([projectId, timestamp])
  @@index([teamId, timestamp])
  @@index([userId, timestamp])
}

model Mission {
  id               String                   @id @default(uuid())
  organizationId   String
  projectId        String?
  orderNumber      String?                  @unique
  title            String?
  description      String?
  status           String                   @default("draft")
  startDate        DateTime?
  endDate          DateTime?
  budget           Decimal?
  createdBy        String?
  data             Json?                    @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  user             User?                    @relation(fields: [createdBy], references: [id])
  organization     Organization             @relation(fields: [organizationId], references: [id])
  project          Project?                 @relation(fields: [projectId], references: [id])
  approvalWorkflow MissionApprovalWorkflow?

  @@index([organizationId])
  @@index([projectId])
  @@index([orderNumber])
}

model MissionApprovalWorkflow {
  id                     String                @id @default(uuid())
  missionId              String                @unique
  overallStatus          String                @default("pending")
  currentStep            Int                   @default(1)
  orderNumber            String?
  orderNumberGeneratedAt DateTime?
  orderNumberGeneratedBy String?
  orderNumberOverridenAt DateTime?
  orderNumberOverridenBy String?
  integrityHash          String?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  approvalSteps          MissionApprovalStep[]
  mission                Mission               @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([orderNumber])
}

model MissionApprovalStep {
  id         String                  @id @default(uuid())
  workflowId String
  role       String
  label      String?
  sequence   Int
  status     String                  @default("EN_ATTENTE")
  decidedBy  String?
  decidedAt  DateTime?
  comment    String?
  signature  String?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  workflow   MissionApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, role])
  @@index([workflowId])
  @@index([role])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  label       String
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserMemory {
  id             String         @id @default(cuid())
  userId         String         @unique
  lastMessage    String?
  lastIntent     String?
  preferences    Json?
  history        Json?
  emotions       Json?
  context        Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  vectorMemories VectorMemory[]

  @@index([userId])
}

model VectorMemory {
  id             String     @id @default(cuid())
  userId         String
  userMemoryId   String
  organizationId String?
  content        String
  embedding      Json?
  metadata       Json?
  intent         String?
  emotion        String?
  source         String     @default("conversation")
  importance     Float      @default(0.5)
  createdAt      DateTime   @default(now())
  expiresAt      DateTime?
  lastAccessed   DateTime   @default(now())
  accessCount    Int        @default(0)
  userMemory     UserMemory @relation(fields: [userMemoryId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userMemoryId])
  @@index([createdAt])
  @@index([expiresAt])
}

model AIMetrics {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String?
  requestType     String
  routeSelected   String
  inputTokens     Int?
  outputTokens    Int?
  costUSD         Decimal?
  latencyMs       Int?
  success         Boolean  @default(true)
  errorMessage    String?
  intentDetected  String?
  emotionDetected String?
  cacheHitRate    Float?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt])
  @@index([routeSelected])
}

model PromptVersion {
  id             String    @id @default(cuid())
  organizationId String?
  name           String
  version        Int
  prompt         String
  model          String?
  description    String?
  isActive       Boolean   @default(false)
  testResults    Json?
  metrics        Json?
  createdAt      DateTime  @default(now())
  activatedAt    DateTime?
  deactivatedAt  DateTime?

  @@unique([name, version])
  @@index([organizationId])
  @@index([isActive])
  @@index([createdAt])
}

model ActionApproval {
  id               String    @id @default(cuid())
  organizationId   String
  userId           String?
  agentName        String
  actionType       String
  riskLevel        String
  confidence       Float
  status           String    @default("AUTO_EXECUTED")
  payload          Json
  result           Json?
  error            String?
  requestedBy      String?
  approvedBy       String?
  rejectedBy       String?
  rejectionComment String?
  requestedAt      DateTime  @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  executedAt       DateTime?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User?     @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([userId])
  @@index([agentName])
  @@index([requestedAt])
  @@index([riskLevel])
}

model Alert {
  id                         String    @id @default(cuid())
  organizationId             String
  projectId                  String
  householdId                String?
  pvId                       String?
  type                       String
  severity                   String
  status                     String    @default("OPEN")
  title                      String
  description                String?
  recommendedAction          String?
  createdAt                  DateTime  @default(now())
  acknowledgedAt             DateTime?
  acknowledgedBy             String?
  resolvedAt                 DateTime?
  resolvedBy                 String?
  escalatedAt                DateTime?
  escalationLevel            Int       @default(0)
  escalationNotificationSent Boolean   @default(false)
  notified                   Boolean   @default(false)
  smsNotified                Boolean   @default(false)
  emailNotified              Boolean   @default(false)
  metadata                   Json?

  @@index([organizationId])
  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@index([type])
  @@index([createdAt])
  @@index([householdId])
}

model AlertConfiguration {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  stockCritical   Int      @default(5)
  budgetThreshold Float    @default(90)
  teamCapacity    Float    @default(85)
  electricityMin  Float    @default(50)
  delayThreshold  Int      @default(5)
  escalationDelay Int      @default(3600)
  escalationLoop  Boolean  @default(true)
  enableSMS       Boolean  @default(true)
  enableEmail     Boolean  @default(true)
  enablePush      Boolean  @default(false)
  enableWhatsApp  Boolean  @default(false)
  quietHourStart  Int?
  quietHourEnd    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

enum TeamRole {
  PREPARATION
  INSTALLATION
  SUPERVISION
  LOGISTICS
}

enum SyncStatus {
  PENDING
  SYNCED
  CONFLICT
}

// ============================================
// FORMATION MODELS
// ============================================

model FormationModule {
  id          String   @id @default(uuid())
  name        String   // Nom du module
  description String?  // Description du module
  duration    Int      // Durée par défaut en jours
  order       Int      @default(0) // Ordre d'affichage
  isActive    Boolean  @default(true) // Module actif
  
  sessionModules FormationSessionModule[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FormationSession {
  id                String   @id @default(uuid())
  region            String   // Région du Sénégal
  salle             String   // Nom de la salle
  maxParticipants   Int      // Nombre max de participants par session
  
  startDate         DateTime // Date de début de la session
  endDate           DateTime? // Date de fin calculée
  
  workSaturday     Boolean  @default(false) // Samedi travaillé
  workSunday       Boolean  @default(false) // Dimanche travaillé
  
  status            String   @default("PLANIFIEE") // PLANIFIEE, EN_COURS, TERMINEE, ANNULEE
  notes             String?  // Notes additionnelles
  
  participants      FormationParticipant[]
  sessionModules    FormationSessionModule[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([region])
  @@index([startDate])
  @@index([status])
}

// Table de liaison session <-> modules (plusieurs modules par session)
model FormationSessionModule {
  id          String   @id @default(uuid())
  sessionId   String
  moduleId    String
  duration    Int      // Durée spécifique pour ce module dans cette session (surécrit la durée par défaut)
  orderIndex  Int      @default(0) // Ordre du module dans la session
  notes       String?  // Notes spécifiques au module
  
  session     FormationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  module      FormationModule  @relation(fields: [moduleId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([sessionId, moduleId]) // Un module ne peut être ajouté qu'une fois par session
  @@index([sessionId])
  @@index([moduleId])
}

model FormationParticipant {
  id          String   @id @default(uuid())
  sessionId   String
  name        String   // Nom et prénom
  email       String?
  phone       String?
  role        String?  // Role (électricien, chef d'équipe, etc.)
  
  attendance  Boolean  @default(false) // Présence
  
  session     FormationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([sessionId])
}
