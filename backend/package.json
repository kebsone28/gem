{
  "name": "proquelec-backend",
  "version": "1.0.0",
  "description": "PROQUELEC Web API - SaaS Électrification Nationale",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node scripts/ensure-backend-port-free.js && node scripts/prisma-generate-safe.js && (npx prisma db push --accept-data-loss || true) && (npx prisma db seed || true) && (node prisma/seed_households.js || true) && node src/server.js",
    "dev": "node scripts/ensure-backend-port-free.js && node scripts/prisma-generate-safe.js && nodemon src/server.js",
    "dev:saas": "npm run dev",
    "build": "npx prisma generate",
    "migrate": "npx prisma migrate deploy",
    "seed": "node prisma/seed.js && node prisma/seed_households.js",
    "seed:households": "node prisma/seed_households.js",
    "sync-up": "node sync_production.js --push",
    "sync-down": "node sync_production.js --pull",
    "lint": "eslint \"src/**/*.js\" --no-eslintrc --config .eslintrc.cjs",
    "format": "prettier --write \"src/**/*.js\"",
    "prisma:validate": "node scripts/validate-prisma-schema.js",
    "prisma:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=prisma/schema.prisma --skip-generate",
    "prisma:sync": "node scripts/sync-prisma.js --full",
    "test": "vitest",
    "test:alerts": "vitest --config vitest.config.alerts.js",
    "test:alerts:watch": "vitest --config vitest.config.alerts.js --watch",
    "test:alerts:ui": "vitest --config vitest.config.alerts.js --ui",
    "test:alerts:coverage": "vitest --config vitest.config.alerts.js --coverage",
    "postinstall": "node -e \"const fs=require('fs'); const path='./node_modules/express-rate-limit/tsconfig.json'; try{const conf=JSON.parse(fs.readFileSync(path,'utf8')); delete conf.extends; fs.writeFileSync(path, JSON.stringify(conf, null, 2));}catch(e){}\""
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/lib-storage": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@sendgrid/mail": "^8.1.6",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.4",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "docx": "^8.4.0",
    "dotenv": "^16.6.1",
    "exceljs": "^3.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-ssh": "^13.2.1",
    "nodemailer": "^8.0.7",
    "pdfmake": "^0.3.7",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "ssh2": "^1.17.0",
    "twilio": "^5.13.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@prisma/client": "6.4.1",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.0.0",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "overrides": {
    "tmp": "^0.2.5",
    "fast-csv": "^4.3.6"
  }
}
