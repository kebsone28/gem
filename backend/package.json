{
  "name": "proquelec-backend",
  "version": "1.0.0",
  "description": "PROQUELEC Web API - SaaS Électrification Nationale",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "npx prisma db push --accept-data-loss && npx prisma db seed && node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "npx prisma generate",
    "migrate": "npx prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "sync-up": "node sync_production.js --push",
    "sync-down": "node sync_production.js --pull",
    "test": "jest"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/lib-storage": "^3.1002.0",
    "@prisma/client": "6.4.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.70.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.10.0",
    "prisma": "6.4.1",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [],
